# EduCore · configuración única de la base de datos.
# Copiar a .env y ajustar. .env NO se commitea.
DB_HOST=db
# Puerto expuesto en el host (para conectar DBeaver/otro cliente desde tu máquina).
# Si ya tienes MySQL/MariaDB local en 3306, cambia solo este valor: la conexión
# interna app<->db siempre usa el 3306 del contenedor y no se ve afectada.
DB_HOST_PORT=3307
DB_NAME=educore
DB_USER=root
DB_PASSWORD=change-me
API_PORT=8080
MATRICULA_HOST=matricula
MATRICULA_PORT=9001
REPORTE_HOST=reportes
REPORTE_PORT=9002
ENTRADA_DIR=/data/entrada
SALIDA_DIR=/data/salida
